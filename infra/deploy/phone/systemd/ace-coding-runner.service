[Unit]
Description=Ace Coding Practice Server Runner
After=network.target ace-coding-backend.service

[Service]
Type=simple
User=Ubuntu
WorkingDirectory=/opt/ace-coding/current/apps/runner
Environment=NODE_ENV=production
Environment=BACKEND_URL=http://127.0.0.1:3100
Environment=RUNNER_POLL_MS=1200
Environment=RUNNER_TIMEOUT_MS=15000
Environment=DOTNET_CLI_TELEMETRY_OPTOUT=1
Environment=DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1
EnvironmentFile=-/etc/ace-coding/runner.env
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
LockPersonality=true
MemoryMax=512M
TasksMax=64

[Install]
WantedBy=multi-user.target

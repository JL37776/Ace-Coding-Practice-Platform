PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
JUDGE_PROVIDER=remote-runner
PUBLIC_BASE_URL=http://127.0.0.1:3000
RUNNER_SHARED_TOKEN=change-me

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ace_coding
MYSQL_USER=ace_coding
MYSQL_PASSWORD=change-me

# Docker judge provider, used when JUDGE_PROVIDER=docker.
DOCKER_JUDGE_IMAGE_PYTHON=ace-judge-python:3.12
DOCKER_JUDGE_IMAGE_JAVASCRIPT=ace-judge-javascript:22
DOCKER_JUDGE_CPUS=0.5
DOCKER_JUDGE_MEMORY=256m
DOCKER_JUDGE_TIMEOUT_MS=10000

# Azure Container Apps Job provider, used when JUDGE_PROVIDER=azure-container-apps.
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_CONTAINER_APP_JOB_PYTHON=
AZURE_CONTAINER_APP_JOB_JAVASCRIPT=
AZURE_LOCATION=australiaeast
